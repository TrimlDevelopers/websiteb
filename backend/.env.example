PORT=3001

# Comma-separated allowed frontend origins (CORS)
FRONTEND_URL=https://triboundtech.com,https://www.triboundtech.com,https://websiteb-f1.onrender.com,http://localhost:5173

# MongoDB Atlas connection string — must include /website (database name)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/website?retryWrites=true&w=majority

# Admin authentication (required for /admin and /api/admin/*)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Or store a bcrypt hash in ADMIN_PASSWORD (starts with $2a$ / $2b$) for stronger storage
JWT_SECRET=change-me-to-a-long-random-secret-min-16-chars
