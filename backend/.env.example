PORT=3001

# Comma-separated allowed frontend origins (CORS)
FRONTEND_URL=https://websiteb-f1.onrender.com,http://localhost:5173
# Optional alias — merged with FRONTEND_URL
# CORS_ORIGINS=https://websiteb-f1.onrender.com,http://localhost:5173

# MongoDB Atlas connection string — must include /website (database name)
# Without a DB name, Atlas defaults to "test" and enquiries won't show in admin.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/website?retryWrites=true&w=majority

# Optional — used only if you re-enable requireAdmin middleware later
# ADMIN_API_KEY=change-me-to-a-long-random-secret
