PORT=3001
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas connection string
# Example: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/tribound?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/tribound?retryWrites=true&w=majority

# Hostinger SMTP — authenticate as the REAL mailbox
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=info@triboundtech.com
SMTP_PASSWORD="YOUR_MAILBOX_PASSWORD"

# Visible From address (alias of info@)
MAIL_FROM=enquiry@triboundtech.com
MAIL_FROM_NAME=Tribound Tech

# Internal notification recipient
CONTACT_TO_EMAIL=info@triboundtech.com
