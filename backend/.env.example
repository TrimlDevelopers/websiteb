PORT=3001

# Comma-separated allowed frontend origins (CORS)
FRONTEND_URL=https://websiteb-f1.onrender.com,http://localhost:5173
# Optional alias — merged with FRONTEND_URL
# CORS_ORIGINS=https://websiteb-f1.onrender.com,http://localhost:5173

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/website?retryWrites=true&w=majority

# Hostinger SMTP — authenticate as the REAL mailbox
SMTP_SERVER=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=info@triboundtech.com
SMTP_PASSWORD="YOUR_MAILBOX_PASSWORD"

# Visible From address (alias of info@)
MAIL_FROM=enquiry@triboundtech.com
MAIL_FROM_NAME=Tribound Tech

# Internal notification recipient
CONTACT_TO_EMAIL=info@triboundtech.com
