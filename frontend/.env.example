# Production site URL (no trailing slash) — canonical URLs, sitemap, Open Graph
VITE_SITE_URL=https://triboundtech.com

# Backend API base URL (no trailing slash)
# Local: leave empty to use Vite proxy (/api -> localhost:3001)
# Production (Render): set to your deployed Express service URL
VITE_API_URL=https://websiteb-backend.onrender.com
